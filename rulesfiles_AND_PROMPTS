**CRITICAL - Overlay Invisibility Implementation**:
```typescript
// hooks/useOverlayVisibility.ts
export function useOverlayVisibility() {
  const [isHidden, setIsHidden] = useState(false);

  useEffect(() => {
    // Method 1: Document Picture-in-Picture (web)
    if ('documentPictureInPicture' in window) {
      // Open Parakeet panel in PiP window — excluded from screen capture
      const pipWindow = await window.documentPictureInPicture.requestWindow({
        width: 400, height: 600,
      });
      // Move overlay DOM into PiP window
    }

    // Method 2: Electron (desktop app)
    if (window.__ELECTRON__) {
      window.electronAPI.setContentProtection(true);
      // Sets WDA_EXCLUDEFROMCAPTURE on Windows, equivalent on macOS
    }
  }, []);
}
```

